{
	"name": "pi-config",
	"private": true,
	"description": "Shared dependencies for ~/.pi extensions",
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit -p tsconfig.json && npm run typecheck:web-tools",
		"typecheck:web-tools": "tsc --noEmit -p agent/extensions/web-tools/tsconfig.json",
		"lint": "oxlint agent/extensions",
		"lint:fix": "oxlint --fix agent/extensions",
		"format": "oxfmt . '!.repos/**' '!agent/extensions/web-tools/**'",
		"format:check": "oxfmt --check . '!.repos/**' '!agent/extensions/web-tools/**'",
		"test": "vitest run"
	},
	"dependencies": {
		"@vue/language-server": "^3.3.5",
		"effect": "^4.0.0-beta.90",
		"html-to-text": "^9.0.5",
		"linkedom": "^0.18.12",
		"turndown": "^7.2.0",
		"turndown-plugin-gfm": "^1.0.2",
		"typescript-language-server": "^5.3.0",
		"vscode-jsonrpc": "^9.0.0",
		"vscode-langservers-extracted": "^4.10.0",
		"vscode-languageserver-types": "^3.18.0"
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "^0.80.2",
		"@earendil-works/pi-coding-agent": "^0.80.2",
		"@earendil-works/pi-tui": "^0.80.2",
		"@types/turndown": "^5.0.5",
		"effect-rules": "^0.3.6",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
