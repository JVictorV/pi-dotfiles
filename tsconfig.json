{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	},
	// web-tools is a vendored extension with its own tsconfig (it needs the DOM lib and
	// relaxed strictness for the HTML parsing pipeline). It is typechecked via
	// `typecheck:web-tools`. node_modules must be listed explicitly because specifying
	// `exclude` overrides TypeScript's default excludes.
	"exclude": ["node_modules", "agent/extensions/web-tools"]
}
